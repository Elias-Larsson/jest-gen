{
  "name": "jest-gen",
  "version": "0.1.0",
  "description": "AI-powered Jest test generator using DeepWiki",
  "type": "module",
  "bin": {
    "jest-gen": "./dist/cli.js"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
