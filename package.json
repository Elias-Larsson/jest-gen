  "keywords": [
    "jest",
    "testing",
    "ai",
    "deepwiki",
    "test-generation"
  ],
  "author": "AsyncFuncAI",
  "license": "MIT",
  "dependencies": {
    "glob": "^11.0.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
